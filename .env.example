PORT=4010
CORS_ORIGIN=http://localhost:3000
CHAIN_NAME="X1 EcoChain Testnet (Maculatus)"
CHAIN_ID=10778
CHAIN_CURRENCY_SYMBOL=X1T
CHAIN_EXPLORER_URL=https://maculatus-scan.x1eco.com/
# Optional: path to contract deployment manifest generated in this repo
DEPLOYMENT_MANIFEST_PATH=./contracts/deployments/latest.json
RPC_URL=https://maculatus-rpc.x1eco.com/
CONTRACT_ADDRESS=0xB36B20436b1D8f67CFbBF83D79F5C000E823418D
AI_DECISION_ANCHOR_ADDRESS=
DEPIN_ANCHOR_ADDRESS=

# DePIN attestation verification
DEPIN_EIP712_DOMAIN_NAME=X1SentinelDePIN
DEPIN_EIP712_DOMAIN_VERSION=1
DEPIN_MAX_CLOCK_SKEW_SECONDS=300
DEPIN_MAX_ATTESTATION_AGE_SECONDS=86400
DEPIN_MAX_REGISTRATION_AGE_SECONDS=259200
DEPIN_NONCE_RETENTION_SECONDS=604800
DEPIN_ATTESTATION_RETENTION_SECONDS=1209600
DEPIN_HEALTH_WINDOW_HOURS=24
DEPIN_REQUIRE_NODE_REGISTRATION=true

# AI scoring engine
AI_SCORING_MODE=heuristic
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
AI_POLICY_WARN_THRESHOLD=50
AI_POLICY_CHALLENGE_THRESHOLD=70
AI_POLICY_BLOCK_THRESHOLD=88
AI_POLICY_MIN_AUTOMATION_CONFIDENCE=0.72
AI_DECISION_RETENTION=400
